# Backend
SECRET_KEY=change-me-to-a-random-256-bit-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

DATABASE_URL=postgresql+asyncpg://ecosphere:ecosphere_secret@postgres:5432/ecosphere
REDIS_URL=redis://redis:6379/0

# AI Assistant — NVIDIA NIM (OpenAI-compatible) endpoint hosting Llama 3.3 70B
LLM_API_KEY=
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=meta/llama-3.3-70b-instruct

# File uploads
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# Frontend
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000
